# 微博 API 版（Qwen3.5）配置示例
# 复制为 .env 后填写真实密钥

# 必填：DashScope API Key
WEIBO_API_KEY=你的密钥

# 可选：兼容接口地址（默认即该值）
WEIBO_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：Qwen3.5 模型名，默认使用该系列大规格型号
WEIBO_MODEL_NAME=qwen3.5-397b-a17b

# 可选：单次最大输出 token（vLLM 微博画像 prompt 较长，默认建议至少 4096）
WEIBO_MAX_TOKENS=4096

# 可选：数据集路径（优先级高于代码默认值）
# Windows 示例：E:\oasis-main\oasis-main\weibo_test\total_data_with_descriptions_transformers.json
# macOS/Linux 示例：weibo_test/total_data_with_descriptions_transformers.json
WEIBO_DATASET_PATH=weibo_test/total_data_with_descriptions_transformers.json

# 可选：输出数据库路径
WEIBO_DB_PATH=weibo_test/weibo_sim_api_qwen35_you.db

# 可选：限流保护参数
# WEIBO_LLM_AGENT_LIMIT=0 表示全部 agent 参与 LLM 回合（更接近 vllm_you 原脚本）
WEIBO_LLM_AGENT_LIMIT=0
WEIBO_LLM_ROUNDS=17
WEIBO_LLM_RETRY=4
WEIBO_LLM_RETRY_WAIT_SECONDS=2
WEIBO_LLM_STEP_INTERVAL_SECONDS=0.8

# 可选：是否打印每回合动作统计（1=打印，0=不打印）
WEIBO_VERBOSE=1

# 可选：是否回滚到旧的 OasisEnv 通用链路（1=回滚旧链路，0=使用新的微博专用 Runner）
WEIBO_USE_LEGACY_OASIS_ENV=0
